# ========== 通用忽略规则 ==========

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE/编辑器配置
.vscode/
.idea/
*.swp
*.swo
*~

# 日志文件
*.log
logs/
*.out

# 临时文件
*.tmp
*.temp
.cache/

# 备份文件
*.bak
*.backup
*.orig

# ========== Go 项目规则 ==========

# 编译后的可执行文件
*.exe
*.dll
*.so
*.dylib

# Go 模块缓存
go.sum
vendor/

# 构建输出
build/
dist/

# ========== Node.js 项目规则 ==========

# Node 模块
node_modules/

# npm 缓存
.npm/
package-lock.json
yarn.lock

# 构建输出
dist/
build/

# 环境变量文件（包含敏感信息）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ========== 本项目特定规则 ==========

# 后端编译产物
backend/server.exe
backend/watertown-backend.exe

# 后端日志
backend/logs/

# 前端构建产物
frontend/dist/
frontend/build/

# 捕获脚本（调试用）
frontend/capture*.js

# 临时背景图片（如果是本地测试用）
# frontend/assets/background.jpg

# 测试文件
*.test.go
*.spec.js
__tests__/
test-results/

# Docker 构建缓存
.dockerignore
